fn test_xmss_sign_verify() {
    let private_key: WOTSTWKey = ([
        4, 6, 1, 2, 6, 8, 4, 2, 3, 5, 7, 9, 0, 2, 4, 6,
        4, 6, 1, 2, 6, 8, 4, 2, 3, 5, 7, 9, 0, 2, 4, 6,
        4, 6, 1, 2, 6, 8, 4, 2, 3, 5, 7, 9, 0, 2, 4, 6,
        4, 6, 1, 2, 6, 8, 4, 2, 3, 5, 7, 9, 0, 2, 4, 6,
    ], [4, 7, 2]);

    let signature: WOTSTWSignature = xmss_signature(671235314, private_key, 13, 468264);

    // =========

    // let private_keys: [WOTSTWKey; 64] = [
    //     private_key, private_key, private_key, private_key,
    //     private_key, private_key, private_key, private_key,
    //     private_key, private_key, private_key, private_key,
    //     private_key, private_key, private_key, private_key,
    //     private_key, private_key, private_key, private_key,
    //     private_key, private_key, private_key, private_key,
    //     private_key, private_key, private_key, private_key,
    //     private_key, private_key, private_key, private_key,
    //     private_key, private_key, private_key, private_key,
    //     private_key, private_key, private_key, private_key,
    //     private_key, private_key, private_key, private_key,
    //     private_key, private_key, private_key, private_key,
    //     private_key, private_key, private_key, private_key,
    //     private_key, private_key, private_key, private_key,
    //     private_key, private_key, private_key, private_key,
    //     private_key, private_key, private_key, private_key,
    // ];

    // let (merkle_root, merkle_path): (u256, [u256; 6]) = get_xmss_public_key(private_keys, 468264, 13);

    // OR

    let merkle_root: u256 = 0x675a2d1cd46d599dcb34619ac0d07116e5dfb29ccf3f2714e505cafcda144cf8;

    let merkle_path: [u256; 6] = [
        0xd2644d0eb38cc59058de23e22c4688d779a856f1c098bf08c84cc8cc89eb9805,
        0x2e5e955990cc83dc1ce12cbb85de62a1db36a6aa091dd909f0a42e75d866e228,
        0x7ae0a8dc7dc8c4ae6594fc872da18d2fd04661a24c7a2ea69cfaad1adf102bad,
        0xb9d809dcc0b32e348a6ed8791024146dbd85a6d88eaa90d99b3bf9489ee9b6b8,
        0xdd551441839463f1d686f5241b06336140dfb8868b21f293cad170aeacc4ed18,
        0x273b35fbb7c27a0e0951b5e2509c1fbded734fe9cf1789fe933ab66c464b1aeb,
    ];

    // =========

    let proof: XMSSSignProof = (671235314, signature, merkle_path, 13, 468264, merkle_root);

    xmss_verify(proof);
}

