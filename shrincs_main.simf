fn sphincs_restore_wots_tw_signature_map_arr_16 (arr: [u128; 16], ctx: (u128, u32, u8, u32, Ctx8, u32, u32, u64, u32)) -> ([u128; 16], (u128, u32, u8, u32, Ctx8, u32, u32, u64, u32)) { let (arr1, arr2): ([u128; 8], [u128; 8]) = <[u128; 16]>::into(arr); let (res1, ctx): ([u128; 8], (u128, u32, u8, u32, Ctx8, u32, u32, u64, u32)) = sphincs_restore_wots_tw_signature_map_arr_8 (arr1, ctx); let (res2, ctx): ([u128; 8], (u128, u32, u8, u32, Ctx8, u32, u32, u64, u32)) = sphincs_restore_wots_tw_signature_map_arr_8 (arr2, ctx); let res: [u128; 16] = <([u128; 8], [u128; 8])>::into((res1, res2)); (res, ctx) }
fn sphincs_restore_wots_tw_signature_map_arr_32 (arr: [u128; 32], ctx: (u128, u32, u8, u32, Ctx8, u32, u32, u64, u32)) -> ([u128; 32], (u128, u32, u8, u32, Ctx8, u32, u32, u64, u32)) { let (arr1, arr2): ([u128; 16], [u128; 16]) = <[u128; 32]>::into(arr); let (res1, ctx): ([u128; 16], (u128, u32, u8, u32, Ctx8, u32, u32, u64, u32)) = sphincs_restore_wots_tw_signature_map_arr_16 (arr1, ctx); let (res2, ctx): ([u128; 16], (u128, u32, u8, u32, Ctx8, u32, u32, u64, u32)) = sphincs_restore_wots_tw_signature_map_arr_16 (arr2, ctx); let res: [u128; 32] = <([u128; 16], [u128; 16])>::into((res1, res2)); (res, ctx) }
fn sphincs_restore_wots_tw_signature_map_arr_64 (arr: [u128; 64], ctx: (u128, u32, u8, u32, Ctx8, u32, u32, u64, u32)) -> ([u128; 64], (u128, u32, u8, u32, Ctx8, u32, u32, u64, u32)) { let (arr1, arr2): ([u128; 32], [u128; 32]) = <[u128; 64]>::into(arr); let (res1, ctx): ([u128; 32], (u128, u32, u8, u32, Ctx8, u32, u32, u64, u32)) = sphincs_restore_wots_tw_signature_map_arr_32 (arr1, ctx); let (res2, ctx): ([u128; 32], (u128, u32, u8, u32, Ctx8, u32, u32, u64, u32)) = sphincs_restore_wots_tw_signature_map_arr_32 (arr2, ctx); let res: [u128; 64] = <([u128; 32], [u128; 32])>::into((res1, res2)); (res, ctx) }


fn sphincs_wots_tw_assert_eq_arr_1 (arr1: [u128; 1], arr2: [u128; 1]) { let el1: u128 = <[u128; 1]>::into(arr1); let el2: u128 = <[u128; 1]>::into(arr2); assert!(eq_128(el1, el2)); }
fn sphincs_wots_tw_assert_eq_arr_2 (arr1: [u128; 2], arr2: [u128; 2]) { let (arr1_1, arr1_2): ([u128; 1], [u128; 1]) = <[u128; 2]>::into(arr1); let (arr2_1, arr2_2): ([u128; 1], [u128; 1]) = <[u128; 2]>::into(arr2); sphincs_wots_tw_assert_eq_arr_1 (arr1_1, arr2_1); sphincs_wots_tw_assert_eq_arr_1 (arr1_2, arr2_2); }
fn sphincs_wots_tw_assert_eq_arr_4 (arr1: [u128; 4], arr2: [u128; 4]) { let (arr1_1, arr1_2): ([u128; 2], [u128; 2]) = <[u128; 4]>::into(arr1); let (arr2_1, arr2_2): ([u128; 2], [u128; 2]) = <[u128; 4]>::into(arr2); sphincs_wots_tw_assert_eq_arr_2 (arr1_1, arr2_1); sphincs_wots_tw_assert_eq_arr_2 (arr1_2, arr2_2); }
fn sphincs_wots_tw_assert_eq_arr_8 (arr1: [u128; 8], arr2: [u128; 8]) { let (arr1_1, arr1_2): ([u128; 4], [u128; 4]) = <[u128; 8]>::into(arr1); let (arr2_1, arr2_2): ([u128; 4], [u128; 4]) = <[u128; 8]>::into(arr2); sphincs_wots_tw_assert_eq_arr_4 (arr1_1, arr2_1); sphincs_wots_tw_assert_eq_arr_4 (arr1_2, arr2_2); }
fn sphincs_wots_tw_assert_eq_arr_16 (arr1: [u128; 16], arr2: [u128; 16]) { let (arr1_1, arr1_2): ([u128; 8], [u128; 8]) = <[u128; 16]>::into(arr1); let (arr2_1, arr2_2): ([u128; 8], [u128; 8]) = <[u128; 16]>::into(arr2); sphincs_wots_tw_assert_eq_arr_8 (arr1_1, arr2_1); sphincs_wots_tw_assert_eq_arr_8 (arr1_2, arr2_2); }
fn sphincs_wots_tw_assert_eq_arr_32 (arr1: [u128; 32], arr2: [u128; 32]) { let (arr1_1, arr1_2): ([u128; 16], [u128; 16]) = <[u128; 32]>::into(arr1); let (arr2_1, arr2_2): ([u128; 16], [u128; 16]) = <[u128; 32]>::into(arr2); sphincs_wots_tw_assert_eq_arr_16 (arr1_1, arr2_1); sphincs_wots_tw_assert_eq_arr_16 (arr1_2, arr2_2); }
fn sphincs_wots_tw_assert_eq_arr_64 (arr1: [u128; 64], arr2: [u128; 64]) { let (arr1_1, arr1_2): ([u128; 32], [u128; 32]) = <[u128; 64]>::into(arr1); let (arr2_1, arr2_2): ([u128; 32], [u128; 32]) = <[u128; 64]>::into(arr2); sphincs_wots_tw_assert_eq_arr_32 (arr1_1, arr2_1); sphincs_wots_tw_assert_eq_arr_32 (arr1_2, arr2_2); }

fn sphincs_get_wots_tw_public_key(private_key: SPHINCSWOTSTWKey, key_idx: u32, hash_ctx: Ctx8, layer_adrs: u32, tree_adrs_1: u32, tree_adrs_2: u64, wots_type: u32) -> SPHINCSWOTSTWKey {
    let private_key: SPHINCSWOTSTWKey = private_key;
    let (pk, _): ([u128; 64], (u32, u32, Ctx8, u32, u32, u64, u32)) = sphincs_get_wots_tw_pub_key_map_arr_64(private_key, (0, key_idx, hash_ctx, layer_adrs, tree_adrs_1, tree_adrs_2, wots_type));

    pk
}

type SPHINCSMerklePath = [u128; 12];

type XMSSSignature = (SPHINCSWOTSTWSignature, SPHINCSMerklePath);

fn sphincs_get_wots_tw_public_key_xmss(el: SPHINCSWOTSTWKey, ctx: (u32, Ctx8, u32, u32, u64)) -> (SPHINCSWOTSTWKey, (u32, Ctx8, u32, u32, u64)) {
    let (key_idx, hash_ctx, layer_adrs, tree_adrs_1, tree_adrs_2): (u32, Ctx8, u32, u32, u64) = ctx;

    let (_, new_key_idx): (bool, u32) = jet::add_32(key_idx, 1);
    (sphincs_get_wots_tw_public_key(el, key_idx, hash_ctx, layer_adrs, tree_adrs_1, tree_adrs_2, 2), (new_key_idx, hash_ctx, layer_adrs, tree_adrs_1, tree_adrs_2))
}

fn sphincs_hash_u128_array_iter(el: u128, ctx: Ctx8) -> Ctx8 {
    jet::sha_256_ctx_8_add_16(ctx, el)
}

fn sphincs_hash_leaf_xmss(public_key: SPHINCSWOTSTWKey, ctx: (u32, Ctx8, u32, u32, u64, u32)) -> (u128, (u32, Ctx8, u32, u32, u64, u32)) {
    let message_key: SPHINCSWOTSTWKey = public_key;
    let (key_index, hash_ctx, layer_adrs, tree_adrs_1, tree_adrs_2, pk_type): (u32, Ctx8, u32, u32, u64, u32) = ctx;

    let hash: Ctx8 = add_adrs_to_ctx8(hash_ctx, layer_adrs, tree_adrs_1, tree_adrs_2, pk_type, key_index, 0);
    let hash: Ctx8 = array_fold::<sphincs_hash_u128_array_iter, 64>(message_key, hash);
    let (leaf, _): (u128, u128) = <u256>::into(jet::sha_256_ctx_8_finalize(hash));

    let (_, new_key_idx): (bool, u32) = jet::add_32(key_index, 1);
    (leaf, (new_key_idx, hash_ctx, layer_adrs, tree_adrs_1, tree_adrs_2, pk_type))
}

fn sphincs_hash_node_xmss(left: u128, right: u128, ctx: (u32, u32, Ctx8, u32, u32, u64)) -> u128 {
    let (height, node_idx, hash_ctx, layer_adrs, tree_adrs_1, tree_adrs_2): (u32, u32, Ctx8, u32, u32, u64) = ctx;

    let hash: Ctx8 = add_adrs_to_ctx8(hash_ctx, layer_adrs, tree_adrs_1, tree_adrs_2, 5, 0, <(u32, u32)>::into((height, node_idx)));
    let hash: Ctx8 = jet::sha_256_ctx_8_add_16(hash, left);
    let hash: Ctx8 = jet::sha_256_ctx_8_add_16(hash, right);
    let (node, _): (u128, u128) = <u256>::into(jet::sha_256_ctx_8_finalize(hash));

    node
}

fn sphincs_xmss_root_from_path_iter(el: u128, ctx: (u128, u32, u32, Ctx8, u32, u32, u64)) -> (u128, u32, u32, Ctx8, u32, u32, u64) {
    let (current_hash, height, key_idx, hash_ctx, layer_adrs, tree_adrs_1, tree_adrs_2): (u128, u32, u32, Ctx8, u32, u32, u64) = ctx;

    let (new_key_idx, rem): (u32, u32) = jet::div_mod_32(key_idx, 2);
    let (left, right): (u128, u128) = match jet::eq_32(rem, 0) {
        true => (current_hash, el),
        false => (el, current_hash),
    };

    let current_hash: u128 = sphincs_hash_node_xmss(left, right, (height, new_key_idx, hash_ctx, layer_adrs, tree_adrs_1, tree_adrs_2));
    let (_, new_height): (bool, u32) = jet::add_32(height, 1);
    (current_hash, new_height, new_key_idx, hash_ctx, layer_adrs, tree_adrs_1, tree_adrs_2)
}

fn sphincs_get_xmss_pub_key(signature: XMSSSignature, pk_seed: u128, pk_root: u128, message: u128, key_index: u32, hash_ctx: Ctx8, layer_adrs: u32, tree_adrs_1: u32, tree_adrs_2: u64) -> u128 {
    let (signature, merkle_path): XMSSSignature = signature;
    let (_, counter, message_signature): SPHINCSWOTSTWSignature = signature;

    let hash: Ctx8 = jet::sha_256_ctx_8_init();
    let hash: Ctx8 = add_adrs_to_ctx8(hash, layer_adrs, tree_adrs_1, tree_adrs_2, 9, 0, 0);
    let hash: Ctx8 = jet::sha_256_ctx_8_add_16(hash, message);
    let hash: Ctx8 = jet::sha_256_ctx_8_add_4(hash, counter);
    let (message, _): (u128, u128) = <u256>::into(jet::sha_256_ctx_8_finalize(hash));

    let (pk, (_, _, checksum, _, _, _, _, _, _)): ([u128; 64], (u128, u32, u8, u32, Ctx8, u32, u32, u64, u32)) = sphincs_restore_wots_tw_signature_map_arr_64(message_signature, (message, 0, 0, key_index, hash_ctx, layer_adrs, tree_adrs_1, tree_adrs_2, 3));
    assert!(jet::eq_8(checksum, 140));

    let (leaf_hash, _): (u128, (u32, Ctx8, u32, u32, u64, u32)) = sphincs_hash_leaf_xmss(pk, (key_index, hash_ctx, layer_adrs, tree_adrs_1, tree_adrs_2, 4));
    let (merkle_root, _, _, _, _, _, _): (u128, u32, u32, Ctx8, u32, u32, u64) = array_fold::<sphincs_xmss_root_from_path_iter, 12>(merkle_path, (leaf_hash, 1, key_index, hash_ctx, layer_adrs, tree_adrs_1, tree_adrs_2));

    merkle_root
}


type SPHINCSFORSSignaturePart = (u128, [u128; 22]);

type SPHINCSFORSSignature = (u256, u32, ([SPHINCSFORSSignaturePart; 4], [SPHINCSFORSSignaturePart; 1]));

fn sphincs_fors_root_from_path_iter(el: u128, ctx: (u128, Ctx8, u32, u32, u32, u64, u32)) -> (u128, Ctx8, u32, u32, u32, u64, u32) {
    let (node, hash_ctx, key_idx, tree_idx, tree_adrs_1, tree_adrs_2, height): (u128, Ctx8, u32, u32, u32, u64, u32) = ctx;

    let (tree_idx, rem): (u32, u32) = jet::div_mod_32(tree_idx, 2);
    let (left, right): (u128, u128) = match jet::eq_32(rem, 0) {
        true => (node, el),
        false => (el, node),
    };

    let hash: Ctx8 = add_adrs_to_ctx8(hash_ctx, 0, tree_adrs_1, tree_adrs_2, 7, key_idx, <(u32, u32)>::into((height, tree_idx)));
    let hash: Ctx8 = jet::sha_256_ctx_8_add_16(hash, left);
    let hash: Ctx8 = jet::sha_256_ctx_8_add_16(hash, right);
    let (node, _): (u128, u128) = <u256>::into(jet::sha_256_ctx_8_finalize(hash));

    let (_, height): (bool, u32) = jet::add_32(height, 1);
    (node, hash_ctx, key_idx, tree_idx, tree_adrs_1, tree_adrs_2, height)
}

fn get_22_bits_at(message: u256, idx: u8) -> u32 {
    assert!(jet::lt_8(idx, 6));
    let (_, shift): (u8, u8) = <u16>::into(jet::multiply_8(idx, 22));
    let (_, shift): (bool, u8) = jet::subtract_8(234, shift);
    let shifted_msg: u256 = right_shift_256(message, shift);
    let (_, (_, (_, shifted_msg))): (u128, (u64, (u32, u32))) = <u256>::into(shifted_msg);
    jet::and_32(shifted_msg, 0x003FFFFF)
}

fn sphincs_fors_root_from_path(part: SPHINCSFORSSignaturePart, ctx: (Ctx8, u256, u32, u32, u64)) -> (u128, (Ctx8, u256, u32, u32, u64)) {
    let (hash_ctx, message, idx_idx, tree_adrs_1, tree_adrs_2): (Ctx8, u256, u32, u32, u64) = ctx;
    let (sk_value, path): SPHINCSFORSSignaturePart = part;

    let (_, (_, idx_idx_8)): (u16, (u8, u8)) = <u32>::into(idx_idx);
    let key_idx: u32 = get_22_bits_at(message, idx_idx_8);

    let hash: Ctx8 = add_adrs_to_ctx8(hash_ctx, 0, tree_adrs_1, tree_adrs_2, 6, idx_idx, <(u32, u32)>::into((0, key_idx)));
    let hash: Ctx8 = jet::sha_256_ctx_8_add_16(hash, sk_value);
    let (leaf, _): (u128, u128) = <u256>::into(jet::sha_256_ctx_8_finalize(hash));

    let (root, _, _, _, _, _, _): (u128, Ctx8, u32, u32, u32, u64, u32) = array_fold::<sphincs_fors_root_from_path_iter, 22>(path, (leaf, hash_ctx, idx_idx, key_idx, tree_adrs_1, tree_adrs_2, 1));

    let (_, new_idx_idx): (bool, u32) = jet::add_32(idx_idx, 1);
    (root, (hash_ctx, message, new_idx_idx, tree_adrs_1, tree_adrs_2))
}

fn sphincs_fors_root_from_path_map_arr_1 (arr: [SPHINCSFORSSignaturePart; 1], ctx: (Ctx8, u256, u32, u32, u64)) -> ([u128; 1], (Ctx8, u256, u32, u32, u64)) { let elt: SPHINCSFORSSignaturePart = <[SPHINCSFORSSignaturePart; 1]>::into(arr); let (res, ctx): (u128, (Ctx8, u256, u32, u32, u64)) = sphincs_fors_root_from_path(elt, ctx); ([res], ctx) }
fn sphincs_fors_root_from_path_map_arr_2 (arr: [SPHINCSFORSSignaturePart; 2], ctx: (Ctx8, u256, u32, u32, u64)) -> ([u128; 2], (Ctx8, u256, u32, u32, u64)) { let (arr1, arr2): ([SPHINCSFORSSignaturePart; 1], [SPHINCSFORSSignaturePart; 1]) = <[SPHINCSFORSSignaturePart; 2]>::into(arr); let (res1, ctx): ([u128; 1], (Ctx8, u256, u32, u32, u64)) = sphincs_fors_root_from_path_map_arr_1 (arr1, ctx); let (res2, ctx): ([u128; 1], (Ctx8, u256, u32, u32, u64)) = sphincs_fors_root_from_path_map_arr_1 (arr2, ctx); let res: [u128; 2] = <([u128; 1], [u128; 1])>::into((res1, res2)); (res, ctx) }
fn sphincs_fors_root_from_path_map_arr_4 (arr: [SPHINCSFORSSignaturePart; 4], ctx: (Ctx8, u256, u32, u32, u64)) -> ([u128; 4], (Ctx8, u256, u32, u32, u64)) { let (arr1, arr2): ([SPHINCSFORSSignaturePart; 2], [SPHINCSFORSSignaturePart; 2]) = <[SPHINCSFORSSignaturePart; 4]>::into(arr); let (res1, ctx): ([u128; 2], (Ctx8, u256, u32, u32, u64)) = sphincs_fors_root_from_path_map_arr_2 (arr1, ctx); let (res2, ctx): ([u128; 2], (Ctx8, u256, u32, u32, u64)) = sphincs_fors_root_from_path_map_arr_2 (arr2, ctx); let res: [u128; 4] = <([u128; 2], [u128; 2])>::into((res1, res2)); (res, ctx) }

fn fors_hash_u128_array_iter(el: u128, ctx: Ctx8) -> Ctx8 {
    jet::sha_256_ctx_8_add_16(ctx, el)
}

fn sphincs_get_fors_pub_key(signature: SPHINCSFORSSignature, hash_ctx: Ctx8, message: u256, tree_adrs_1: u32, tree_adrs_2: u64) -> u128 {
    let (_, _, (parts_4, parts_1)): SPHINCSFORSSignature = signature;

    let last_bits: u32 = get_22_bits_at(message, 5);
    assert!(jet::eq_32(last_bits, 0));

    let (roots_4, _): ([u128; 4], (Ctx8, u256, u32, u32, u64)) = sphincs_fors_root_from_path_map_arr_4(parts_4, (hash_ctx, message, 0, tree_adrs_1, tree_adrs_2));
    let (roots_1, _): ([u128; 1], (Ctx8, u256, u32, u32, u64)) = sphincs_fors_root_from_path_map_arr_1(parts_1, (hash_ctx, message, 4, tree_adrs_1, tree_adrs_2));

    let hash: Ctx8 = add_adrs_to_ctx8(hash_ctx, 0, tree_adrs_1, tree_adrs_2, 8, 0, 0);
    let hash: Ctx8 = array_fold::<fors_hash_u128_array_iter, 4>(roots_4, hash);
    let [el]: [u128; 1] = roots_1;
    let hash: Ctx8 = jet::sha_256_ctx_8_add_16(hash, el);

    let (pk, _): (u128, u128) = <u256>::into(jet::sha_256_ctx_8_finalize(hash));
    pk
}










type SPHINCSPK = (u128, u128);

type XMSSHTSignature = [XMSSSignature; 2];

type SPHINCSSignature = (SPHINCSFORSSignature, XMSSHTSignature);

type SPHINCSSignProof = (u128, SPHINCSPK, SPHINCSSignature);

fn sphincs_root_from_path_iter(el: XMSSSignature, ctx: (u128, u128, u128, u32, Ctx8, u32, u64, u32)) -> (u128, u128, u128, u32, Ctx8, u32, u64, u32) {
    let (pk_seed, pk_root, message, key_index, hash_ctx, layer_adrs, tree_adrs_2, idx): (u128, u128, u128, u32, Ctx8, u32, u64, u32) = ctx;
    let pub_key: u128 = sphincs_get_xmss_pub_key(el, pk_seed, pk_root, message, key_index, hash_ctx, layer_adrs, 0, tree_adrs_2);

    let key_index: u32 = jet::and_32(idx, 0x00000FFF);
    let idx: u32 = jet::right_shift_32(12, idx);
    let tree_adrs: u64 = <(u32, u32)>::into((0, jet::and_32(idx, 0x00000FFF)));

    let (_, layer_adrs): (bool, u32) = jet::add_32(layer_adrs, 1);

    (pk_seed, pk_root, pub_key, key_index, hash_ctx, layer_adrs, tree_adrs, idx)
}

fn ht_verify(signature: XMSSHTSignature, pk_seed: u128, message: u128, hash_ctx: Ctx8, tree_adrs_2: u64, leaf_idx: u32, pk_root: u128, idx: u32) -> u128 {
    let (_, _, root, _, _, _, _, _): (u128, u128, u128, u32, Ctx8, u32, u64, u32) = array_fold::<sphincs_root_from_path_iter, 2>(signature, (pk_seed, pk_root, message, leaf_idx, hash_ctx, 0, tree_adrs_2, idx));
    root
}

fn sphincs_verify(proof: SPHINCSSignProof, hash_ctx: Ctx8) -> u128 {
    let (message_hash, pk, signature): SPHINCSSignProof = proof;
    let (pk_seed, pk_root): SPHINCSPK = pk;
    let (fors_signature, xmss_ht_signature): SPHINCSSignature = signature;
    let (r, counter, _): SPHINCSFORSSignature = fors_signature;

    let hash: Ctx8 = jet::sha_256_ctx_8_init();
    let hash: Ctx8 = add_adrs_to_ctx8(hash, 0, 0, 0, 10, 0, 0);
    let hash: Ctx8 = jet::sha_256_ctx_8_add_32(hash, r);
    let hash: Ctx8 = jet::sha_256_ctx_8_add_4(hash, counter);
    let hash: Ctx8 = jet::sha_256_ctx_8_add_16(hash, pk_seed);
    let hash: Ctx8 = jet::sha_256_ctx_8_add_16(hash, pk_root);
    let hash: Ctx8 = jet::sha_256_ctx_8_add_16(hash, message_hash);
    let message: u256 = jet::sha_256_ctx_8_finalize(hash);

    let (_, ((leaf_part, _), _)): (u128, ((u32, u32), u64)) = <u256>::into(message);
    let idx: u32 = jet::right_shift_32(8, jet::left_shift_32(4, leaf_part));
    let leaf_adrs: u32 = jet::and_32(idx, 0x00000FFF);
    let idx: u32 = jet::right_shift_32(12, idx);
    let tree_adrs: u64 = <(u32, u32)>::into((0, jet::and_32(idx, 0x00000FFF)));

    let fors_pk: u128 = sphincs_get_fors_pub_key(fors_signature, hash_ctx, message, 0, 0);

    ht_verify(xmss_ht_signature, pk_seed, fors_pk, hash_ctx, tree_adrs, leaf_adrs, pk_root, idx)
}


type UXMSSSignature = (SPHINCSWOTSTWSignature, List<u128, 512>, u32);

type UXMSSSignProof = (u128, SPHINCSPK, UXMSSSignature);

fn shrincs_get_root_from_path_iter(el: u128, ctx: (u128, bool, Ctx8, u32)) -> (u128, bool, Ctx8, u32) {
    let (node, is_right_child, hash_ctx, tree_height): (u128, bool, Ctx8, u32) = ctx;

    let (left, right): (u128, u128) = match is_right_child {
        true => (el, node),
        false => (node, el),
    };

    let hash: Ctx8 = add_adrs_to_ctx8(hash_ctx, 0, 0, 0, 2, 0, <(u32, u32)>::into((tree_height, 0)));
    let hash: Ctx8 = jet::sha_256_ctx_8_add_16(hash, left);
    let hash: Ctx8 = jet::sha_256_ctx_8_add_16(hash, right);

    let (hash, _): (u128, u128) = <u256>::into(jet::sha_256_ctx_8_finalize(hash));

    let (_, tree_height): (bool, u32) = jet::add_32(tree_height, 1);

    (hash, false, hash_ctx, tree_height)
}

fn restore_uxmss_signature(proof: UXMSSSignProof, hash_ctx: Ctx8) -> u128 {
    let (message, pk, signature): UXMSSSignProof = proof;
    let (public_parameter, root): SPHINCSPK = pk;
    let (wots_signature, merkle_path, key_idx): UXMSSSignature = signature;
    let (r, counter, message_signature): SPHINCSWOTSTWSignature = wots_signature;

    let hash: Ctx8 = jet::sha_256_ctx_8_init();
    let hash: Ctx8 = add_adrs_to_ctx8(hash, 0, 0, 0, 11, 0, 0);
    let hash: Ctx8 = jet::sha_256_ctx_8_add_32(hash, r);
    let hash: Ctx8 = jet::sha_256_ctx_8_add_16(hash, public_parameter);
    let hash: Ctx8 = jet::sha_256_ctx_8_add_16(hash, root);
    let hash: Ctx8 = jet::sha_256_ctx_8_add_16(hash, message);
    let (message, _): (u128, u128) = <u256>::into(jet::sha_256_ctx_8_finalize(hash));

    let hash: Ctx8 = jet::sha_256_ctx_8_init();
    let hash: Ctx8 = add_adrs_to_ctx8(hash, 0, 0, 0, 9, 0, 0);
    let hash: Ctx8 = jet::sha_256_ctx_8_add_16(hash, message);
    let hash: Ctx8 = jet::sha_256_ctx_8_add_4(hash, counter);
    let (message, _): (u128, u128) = <u256>::into(jet::sha_256_ctx_8_finalize(hash));

    let (pk, (_, _, checksum, _, _, _, _, _, _)): ([u128; 64], (u128, u32, u8, u32, Ctx8, u32, u32, u64, u32)) = sphincs_restore_wots_tw_signature_map_arr_64(message_signature, (message, 0, 0, key_idx, hash_ctx, 0, 0, 0, 0));
    assert!(jet::eq_8(checksum, 140));

    let (leaf, _): (u128, (u32, Ctx8, u32, u32, u64, u32)) = sphincs_hash_leaf_xmss(pk, (key_idx, hash_ctx, 0, 0, 0, 1));


    let is_right_child: bool = jet::eq_32(key_idx, 206);
    let (_, tree_height): (bool, u32) = jet::subtract_32(206, key_idx);

    let (root, _, _, _): (u128, bool, Ctx8, u32) = fold::<shrincs_get_root_from_path_iter, 512>(merkle_path, (leaf, is_right_child, hash_ctx, tree_height));
    root
}


type SHRINCSSignProof = (u128, SPHINCSPK, Either<UXMSSSignature, SPHINCSSignature>, u128);

fn shrincs_verify(proof: SHRINCSSignProof) {
    let (message, seed_root, signature, root_part): SHRINCSSignProof = proof;
    let (public_parameter, expected_root): SPHINCSPK = seed_root;

    let hash_ctx: Ctx8 = jet::sha_256_ctx_8_init();
    let hash_ctx: Ctx8 = jet::sha_256_ctx_8_add_16(hash_ctx, public_parameter);
    let hash_ctx: Ctx8 = jet::sha_256_ctx_8_add_32(hash_ctx, 0);
    let hash_ctx: Ctx8 = jet::sha_256_ctx_8_add_16(hash_ctx, 0);

    let roots: u256 = match signature {
        Left(uxmss: UXMSSSignature) => {
            <(u128, u128)>::into((restore_uxmss_signature((message, seed_root, uxmss), hash_ctx), root_part))
        },
        Right(sphincs: SPHINCSSignature) => {
            <(u128, u128)>::into((root_part, sphincs_verify((message, seed_root, sphincs), hash_ctx)))
        },
    };

    let hash: Ctx8 = add_adrs_to_ctx8(hash_ctx, 0, 0, 0, 14, 0, 0);
    let hash: Ctx8 = jet::sha_256_ctx_8_add_32(hash, roots);
    let (root, _): (u128, u128) = <u256>::into(jet::sha_256_ctx_8_finalize(hash));
    assert!(eq_128(root, expected_root));
}

fn main() {
    shrincs_verify(witness::PROOF);
}
