


fn eq_128(val1: u128, val2: u128) -> bool {
    jet::eq_256(<(u128, u128)>::into((0, val1)), <(u128, u128)>::into((0, val2)))
}

fn right_shift_256(value: u256, shift: u8) -> u256 {
    let (a, b, c, d): (u64, u64, u64, u64) = <u256>::into(value);

    let (a, b, c, d): (u64, u64, u64, u64) = match jet::lt_8(shift, 64) {
        true => (a, b, c, d),
        false => {
            match jet::lt_8(shift, 128) {
                true => (0, a, b, c),
                false => {
                    match jet::lt_8(shift, 192) {
                        true => (0, 0, a, b),
                        false => (0, 0, 0, a),
                    }
                }
            }
        }
    };

    let shift: u8 = jet::modulo_8(shift, 64);
    let (_, left_shift): (bool, u8) = jet::subtract_8(64, shift);

    let new_d: u64 = jet::or_64(jet::left_shift_64(left_shift, c), jet::right_shift_64(shift, d));
    let new_c: u64 = jet::or_64(jet::left_shift_64(left_shift, b), jet::right_shift_64(shift, c));
    let new_b: u64 = jet::or_64(jet::left_shift_64(left_shift, a), jet::right_shift_64(shift, b));
    let new_a: u64 = jet::right_shift_64(shift, a);

    <(u64, u64, u64, u64)>::into((new_a, new_b, new_c, new_d))
}

fn right_shift_128(value: u128, shift: u8) -> u128 {
    let (a, b, c, d): (u32, u32, u32, u32) = <u128>::into(value);

    let (a, b, c, d): (u32, u32, u32, u32) = match jet::lt_8(shift, 32) {
        true => (a, b, c, d),
        false => {
            match jet::lt_8(shift, 64) {
                true => (0, a, b, c),
                false => {
                    match jet::lt_8(shift, 96) {
                        true => (0, 0, a, b),
                        false => (0, 0, 0, a),
                    }
                }
            }
        }
    };

    let shift: u8 = jet::modulo_8(shift, 32);
    let (_, left_shift): (bool, u8) = jet::subtract_8(32, shift);

    let new_d: u32 = jet::or_32(jet::left_shift_32(left_shift, c), jet::right_shift_32(shift, d));
    let new_c: u32 = jet::or_32(jet::left_shift_32(left_shift, b), jet::right_shift_32(shift, c));
    let new_b: u32 = jet::or_32(jet::left_shift_32(left_shift, a), jet::right_shift_32(shift, b));
    let new_a: u32 = jet::right_shift_32(shift, a);

    <(u32, u32, u32, u32)>::into((new_a, new_b, new_c, new_d))
}

fn get_bit_at(value: u256, possition: u8) -> u1 {
    let (a, b, c, d): (u64, u64, u64, u64) = <u256>::into(value);

    let part: u64 = match jet::lt_8(possition, 64) {
        true => d,
        false => {
            match jet::lt_8(possition, 128) {
                true => c,
                false => {
                    match jet::lt_8(possition, 192) {
                        true => b,
                        false => a,
                    }
                },
            }
        },
    };

    let (_, in_part_possition): (u8, u8) = jet::div_mod_8(possition, 64);

    <bool>::into(jet::lt_64(0, jet::and_64(part, jet::left_shift_64(in_part_possition, 1))))
}

fn get_byte_at(value: u256, possition: u8) -> u8 {
    assert!(jet::lt_8(possition, 32));
    let (a, b, c, d): (u64, u64, u64, u64) = <u256>::into(value);

    let part: u64 = match jet::lt_8(possition, 8) {
        true => d,
        false => {
            match jet::lt_8(possition, 16) {
                true => c,
                false => {
                    match jet::lt_8(possition, 24) {
                        true => b,
                        false => a,
                    }
                },
            }
        },
    };

    let possition: u8 = jet::modulo_8(possition, 8);
    let (a, b, c, d): (u16, u16, u16, u16) = <u64>::into(part);

    let part: u16 = match jet::lt_8(possition, 2) {
        true => d,
        false => {
            match jet::lt_8(possition, 4) {
                true => c,
                false => {
                    match jet::lt_8(possition, 6) {
                        true => b,
                        false => a,
                    }
                },
            }
        },
    };

    let possition: u8 = jet::modulo_8(possition, 2);
    let (a, b): (u8, u8) = <u16>::into(part);
    match jet::eq_8(possition, 0) {
        true => b,
        false => a,
    }
}

fn get_byte_at_128(value: u128, possition: u8) -> u8 {
    assert!(jet::lt_8(possition, 16));
    let (a, b, c, d): (u32, u32, u32, u32) = <u128>::into(value);

    let part: u32 = match jet::lt_8(possition, 4) {
        true => a,
        false => {
            match jet::lt_8(possition, 8) {
                true => b,
                false => {
                    match jet::lt_8(possition, 12) {
                        true => c,
                        false => d,
                    }
                },
            }
        },
    };

    let possition: u8 = jet::modulo_8(possition, 4);
    let (a, b, c, d): (u8, u8, u8, u8) = <u32>::into(part);

    match jet::eq_8(possition, 0) {
        true => a,
        false => {
            match jet::eq_8(possition, 1) {
                true => b,
                false => {
                    match jet::eq_8(possition, 2) {
                        true => c,
                        false => d,
                    }
                },
            }
        },
    }
}

fn get_at_array_iter(el: u256, ctx: (u8, u8, u256)) -> (u8, u8, u256) {
    let (idx, pos, saved): (u8, u8, u256) = ctx;
    match jet::eq_8(idx, pos) {
        true => {
            let (_, new_pos): (bool, u8) = jet::add_8(pos, 1);
            (idx, new_pos, el)
        },
        false => {
            let (_, new_pos): (bool, u8) = jet::add_8(pos, 1);
            (idx, new_pos, saved)
        }
    }
}
fn get_at_array_128_iter(el: u128, ctx: (u32, u32, u128)) -> (u32, u32, u128) {
    let (idx, pos, saved): (u32, u32, u128) = ctx;
    match jet::eq_32(idx, pos) {
        true => {
            let (_, new_pos): (bool, u32) = jet::add_32(pos, 1);
            (idx, new_pos, el)
        },
        false => {
            let (_, new_pos): (bool, u32) = jet::add_32(pos, 1);
            (idx, new_pos, saved)
        }
    }
}



fn add_adrs_to_ctx8(ctx: Ctx8, layer_adrs: u32, tree_adrs1: u32, tree_adrs2: u64, adrs_type: u32, other1: u32, other2: u64) -> Ctx8 {
    let ctx: Ctx8 = jet::sha_256_ctx_8_add_4(ctx, layer_adrs);
    let ctx: Ctx8 = jet::sha_256_ctx_8_add_4(ctx, tree_adrs1);
    let ctx: Ctx8 = jet::sha_256_ctx_8_add_8(ctx, tree_adrs2);
    let ctx: Ctx8 = jet::sha_256_ctx_8_add_4(ctx, adrs_type);
    let ctx: Ctx8 = jet::sha_256_ctx_8_add_4(ctx, other1);
    jet::sha_256_ctx_8_add_8(ctx, other2)
}


fn mgf1_sha_256(r: u128, pk_seed: u128, pk_root: u128, message: u256) -> u256 {
    let hash: Ctx8 = jet::sha_256_ctx_8_init();
    let hash: Ctx8 = jet::sha_256_ctx_8_add_16(hash, r);
    let hash: Ctx8 = jet::sha_256_ctx_8_add_16(hash, pk_seed);
    let hash: Ctx8 = jet::sha_256_ctx_8_add_16(hash, pk_root);

    let hash: Ctx8 = jet::sha_256_ctx_8_add_2(hash, 0);
    let hash: Ctx8 = jet::sha_256_ctx_8_add_32(hash, message);

    let mgf: Ctx8 = jet::sha_256_ctx_8_init();
    let mgf: Ctx8 = jet::sha_256_ctx_8_add_16(mgf, r);
    let mgf: Ctx8 = jet::sha_256_ctx_8_add_16(mgf, pk_seed);
    let mgf: Ctx8 = jet::sha_256_ctx_8_add_32(mgf, jet::sha_256_ctx_8_finalize(hash));
    let mgf: Ctx8 = jet::sha_256_ctx_8_add_4(mgf, 0);

    jet::sha_256_ctx_8_finalize(mgf)
}

type SPHINCSWOTSTWKey = [u128; 64];
type SPHINCSWOTSTWSignature = (u256, u32, [u128; 64]);

type SPHINCSWOTSTWSignProof = (u128, SPHINCSWOTSTWSignature, SPHINCSWOTSTWKey, u32, u128);

fn sphincs_wots_tw_hash_n_times_iter(key_hash: u128, ctx: (u8, u32, u32, Ctx8, u8, u32, u32, u64, u32), counter: u8) -> Either<u128, u128> {
    let (n, chain_idx, key_index, hash_ctx, from_idx, layer_adrs, tree_adrs_1, tree_adrs_2, wots_type): (u8, u32, u32, Ctx8, u8, u32, u32, u64, u32) = ctx;
    let (_, hashed_times): (bool, u8) = jet::add_8(counter, from_idx);

    match jet::eq_8(counter, n) {
        true => Left(key_hash),
        false => {
            let hash: Ctx8 = add_adrs_to_ctx8(hash_ctx, layer_adrs, tree_adrs_1, tree_adrs_2, wots_type, key_index, <(u32, u32)>::into((chain_idx, <(u16, (u8, u8))>::into((0, (0, hashed_times))))));
            let hash: Ctx8 = jet::sha_256_ctx_8_add_16(hash, key_hash);

            let (hash, _): (u128, u128) = <u256>::into(jet::sha_256_ctx_8_finalize(hash));
            Right(hash)
        }
    }
}

fn sphincs_get_wots_tw_pub_key(el: u128, ctx: (u32, u32, Ctx8, u32, u32, u64, u32)) -> (u128, (u32, u32, Ctx8, u32, u32, u64, u32)) {
    let (chain_idx, key_idx, hash_ctx, layer_adrs, tree_adrs_1, tree_adrs_2, wots_type): (u32, u32, Ctx8, u32, u32, u64, u32) = ctx;
    let pk: Either<u128, u128> = for_while::<sphincs_wots_tw_hash_n_times_iter>(el, (3, chain_idx, key_idx, hash_ctx, 0, layer_adrs, tree_adrs_1, tree_adrs_2, wots_type));

    let (_, new_chain_idx): (bool, u32) = jet::add_32(chain_idx, 1);
    (unwrap_left::<u128>(pk), (new_chain_idx, key_idx, hash_ctx, layer_adrs, tree_adrs_1, tree_adrs_2, wots_type))
}

fn sphincs_restore_wots_tw_signature(el: u128, ctx: (u128, u32, u8, u32, Ctx8, u32, u32, u64, u32)) -> (u128, (u128, u32, u8, u32, Ctx8, u32, u32, u64, u32)) {
    let (message_hash, idx, checksum, key_idx, hash_ctx, layer_adrs, tree_adrs_1, tree_adrs_2, wots_type): (u128, u32, u8, u32, Ctx8, u32, u32, u64, u32) = ctx;
    let (_, (_, idx_)): (u16, (u8, u8)) = <u32>::into(idx);
    let byte_idx: u8 = jet::divide_8(idx_, 4);
    let n: u8 = get_byte_at_128(message_hash, byte_idx);

    let (n1, n2, n3, n4): (u2, u2, u2, u2) = <u8>::into(n);
    let idx_mod: u8 = jet::modulo_8(idx_, 4);

    let n: u2 = match jet::eq_8(idx_mod, 0) {
        true => n1,
        false => {
            match jet::eq_8(idx_mod, 1) {
                true => n2,
                false => {
                    match jet::eq_8(idx_mod, 2) {
                        true => n3,
                        false => n4,
                    }
                }
            }
        }
    };

    let n: u8 = <(u4, (u2, u2))>::into((0, (0, n)));

    let (_, s_n): (bool, u8) = jet::subtract_8(3, n);
    let (_, checksum): (bool, u8) = jet::add_8(checksum, n);

    let verify_part: Either<u128, u128> = for_while::<sphincs_wots_tw_hash_n_times_iter>(el, (s_n, idx, key_idx, hash_ctx, n, layer_adrs, tree_adrs_1, tree_adrs_2, wots_type));


    let (_, new_idx): (bool, u32) = jet::add_32(idx, 1);
    (unwrap_left::<u128>(verify_part), (message_hash, new_idx, checksum, key_idx, hash_ctx, layer_adrs, tree_adrs_1, tree_adrs_2, wots_type))
}

fn sphincs_get_wots_tw_pub_key_map_arr_1 (arr: [u128; 1], ctx: (u32, u32, Ctx8, u32, u32, u64, u32)) -> ([u128; 1], (u32, u32, Ctx8, u32, u32, u64, u32)) { let elt: u128 = <[u128; 1]>::into(arr); let (res, ctx): (u128, (u32, u32, Ctx8, u32, u32, u64, u32)) = sphincs_get_wots_tw_pub_key(elt, ctx); ([res], ctx) }
fn sphincs_get_wots_tw_pub_key_map_arr_2 (arr: [u128; 2], ctx: (u32, u32, Ctx8, u32, u32, u64, u32)) -> ([u128; 2], (u32, u32, Ctx8, u32, u32, u64, u32)) { let (arr1, arr2): ([u128; 1], [u128; 1]) = <[u128; 2]>::into(arr); let (res1, ctx): ([u128; 1], (u32, u32, Ctx8, u32, u32, u64, u32)) = sphincs_get_wots_tw_pub_key_map_arr_1 (arr1, ctx); let (res2, ctx): ([u128; 1], (u32, u32, Ctx8, u32, u32, u64, u32)) = sphincs_get_wots_tw_pub_key_map_arr_1 (arr2, ctx); let res: [u128; 2] = <([u128; 1], [u128; 1])>::into((res1, res2)); (res, ctx) }
fn sphincs_get_wots_tw_pub_key_map_arr_4 (arr: [u128; 4], ctx: (u32, u32, Ctx8, u32, u32, u64, u32)) -> ([u128; 4], (u32, u32, Ctx8, u32, u32, u64, u32)) { let (arr1, arr2): ([u128; 2], [u128; 2]) = <[u128; 4]>::into(arr); let (res1, ctx): ([u128; 2], (u32, u32, Ctx8, u32, u32, u64, u32)) = sphincs_get_wots_tw_pub_key_map_arr_2 (arr1, ctx); let (res2, ctx): ([u128; 2], (u32, u32, Ctx8, u32, u32, u64, u32)) = sphincs_get_wots_tw_pub_key_map_arr_2 (arr2, ctx); let res: [u128; 4] = <([u128; 2], [u128; 2])>::into((res1, res2)); (res, ctx) }
fn sphincs_get_wots_tw_pub_key_map_arr_8 (arr: [u128; 8], ctx: (u32, u32, Ctx8, u32, u32, u64, u32)) -> ([u128; 8], (u32, u32, Ctx8, u32, u32, u64, u32)) { let (arr1, arr2): ([u128; 4], [u128; 4]) = <[u128; 8]>::into(arr); let (res1, ctx): ([u128; 4], (u32, u32, Ctx8, u32, u32, u64, u32)) = sphincs_get_wots_tw_pub_key_map_arr_4 (arr1, ctx); let (res2, ctx): ([u128; 4], (u32, u32, Ctx8, u32, u32, u64, u32)) = sphincs_get_wots_tw_pub_key_map_arr_4 (arr2, ctx); let res: [u128; 8] = <([u128; 4], [u128; 4])>::into((res1, res2)); (res, ctx) }
fn sphincs_get_wots_tw_pub_key_map_arr_16 (arr: [u128; 16], ctx: (u32, u32, Ctx8, u32, u32, u64, u32)) -> ([u128; 16], (u32, u32, Ctx8, u32, u32, u64, u32)) { let (arr1, arr2): ([u128; 8], [u128; 8]) = <[u128; 16]>::into(arr); let (res1, ctx): ([u128; 8], (u32, u32, Ctx8, u32, u32, u64, u32)) = sphincs_get_wots_tw_pub_key_map_arr_8 (arr1, ctx); let (res2, ctx): ([u128; 8], (u32, u32, Ctx8, u32, u32, u64, u32)) = sphincs_get_wots_tw_pub_key_map_arr_8 (arr2, ctx); let res: [u128; 16] = <([u128; 8], [u128; 8])>::into((res1, res2)); (res, ctx) }
fn sphincs_get_wots_tw_pub_key_map_arr_32 (arr: [u128; 32], ctx: (u32, u32, Ctx8, u32, u32, u64, u32)) -> ([u128; 32], (u32, u32, Ctx8, u32, u32, u64, u32)) { let (arr1, arr2): ([u128; 16], [u128; 16]) = <[u128; 32]>::into(arr); let (res1, ctx): ([u128; 16], (u32, u32, Ctx8, u32, u32, u64, u32)) = sphincs_get_wots_tw_pub_key_map_arr_16 (arr1, ctx); let (res2, ctx): ([u128; 16], (u32, u32, Ctx8, u32, u32, u64, u32)) = sphincs_get_wots_tw_pub_key_map_arr_16 (arr2, ctx); let res: [u128; 32] = <([u128; 16], [u128; 16])>::into((res1, res2)); (res, ctx) }
